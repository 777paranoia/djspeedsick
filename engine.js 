<script>
window.makeUI = function() {
  if (!__debugAllowed) return;
  if (document.getElementById('debug-menu-box')) return; 

  const box = document.createElement("div");
  box.id = "debug-menu-box";
  box.style.cssText = `
    position:fixed; top:10px; left:10px; z-index:2147483647;
    background:rgba(0,0,0,.85); color:#0f0; font:12px monospace;
    padding:8px; border:1px solid #0f0;
  `;
  box.innerHTML = `
    <div>POV: <span id="pov">?</span></div>
    <div>MODE: <span id="mode">?</span></div>
    <div style="margin-top:6px">
      <button id="prev">◀</button>
      <select id="sel">
        <option value="0">0: Fly Intro</option>
        <option value="1">1: City</option>
        <option value="2">2: Fractal</option>
        <option value="3">3: BH</option>
        <option value="4">4: Mirror</option>
        <option value="5">5: City 2</option>
        <option value="6">6: Ocean</option>
        <option value="7">7: Earth</option>
        <option value="8">8: Goreville</option>
        <option value="9">9: Plane</option>
        <option value="98">98: Left Room</option>
        <option value="99">99: Right Room</option>
      </select>
      <button id="next">▶</button>
    </div>
  `;

  document.body.appendChild(box);
  const sel = box.querySelector("#sel");
  const btnPrev = box.querySelector("#prev");
  const btnNext = box.querySelector("#next");

  function setMode(n){
    n = parseInt(n);
    if (n !== 98 && n !== 99) n = Math.max(0, Math.min(9, n|0)); 
    if (typeof currentEngine !== 'undefined' && currentEngine) currentEngine.destroy(); 
    if (typeof phase !== 'undefined') phase = "open";
    if (typeof blink !== 'undefined') blink = 0;
    if (typeof lastMode !== 'undefined' && typeof mode !== 'undefined') lastMode = mode;
    mode = n; modeSeed++;
    if (mode !== 0) sel.value = mode; 
    currentEngine = new ActiveMode(mode);
  }

  sel.onchange = () => setMode(+sel.value);
  btnPrev.onclick = () => {
    let p = mode - 1; if (p < 0) p = 9; if (mode === 98 || mode === 99) p = 9;
    setMode(p);
  };
  btnNext.onclick = () => {
    let n = mode + 1; if (n > 9) n = 1; if (mode === 98 || mode === 99) n = 1;
    setMode(n);
  };

  setInterval(() => {
    try {
      if (document.getElementById("pov")) {
        document.getElementById("pov").innerText = window.modeSeed || "?";
      }
      if (document.getElementById("mode")) {
        document.getElementById("mode").innerText = window.mode !== undefined ? window.mode : "?";
      }
    } catch(err) {}
  }, 500);
};
