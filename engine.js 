const RSS_SOURCES = [
    "https://thegrayzone.com/feed/",
    "https://www.theblackvault.com/documentarchive/feed/",
    "https://www.paranoidcybersecurity.com/rss/all",
    "https://krebsonsecurity.com/feed/",
    "https://warontherocks.com/feed/",
    "https://www.defenseone.com/rss/all/",
    "https://responsiblestatecraft.org/feeds/feed.rss",
    "https://www.eff.org/rss/updates.xml",
    "https://privacyinternational.org/rss.xml",
    "https://vigilantcitizen.com/feed/",
    "https://www.infowars.com/rss.xml"];
    
function updateIntelligence() {
    const shuffledSources = [...RSS_SOURCES].sort(() => Math.random() - 0.5).slice(0, 4);
    const edges = ['rss-top', 'rss-bottom', 'rss-left', 'rss-right'];
    
    edges.forEach((id, index) => {
        const feedUrl = shuffledSources[index];
        
        fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(feedUrl)}`)
            .then(res => res.json())
            .then(data => {
                let headlines = [];
                if (data.items) data.items.forEach(item => headlines.push(item.title.toUpperCase()));
                if (headlines.length === 0) return;
                
                headlines.sort(() => Math.random() - 0.5);
                
                const el = document.getElementById(id);
                if (el) {
                    const textStr = " +++ " + headlines.join(" +++ ") + " +++ ";
                    el.innerText = textStr.repeat(4);
                    
                    const baseTime = id.includes('left') || id.includes('right') ? 6 : 4;
                    const duration = headlines.length * baseTime * 2;
                    
                    el.style.animationDuration = duration + "s";
                    el.style.animationDelay = "-" + (Math.random() * duration) + "s";
                }
            })
            .catch(() => {});
    });
}

function toggleConky() {
    const sidebar = document.getElementById('conky-sidebar');
    const tickers = document.querySelectorAll('.ticker-wrap');
    
    if (sidebar.style.display === 'none' || sidebar.style.display === '') {
        sidebar.style.display = 'block';
        tickers.forEach(t => t.style.display = 'block');
        updateSystemParams(); 
        updateIntelligence();
    } else {
        sidebar.style.display = 'none';
        tickers.forEach(t => t.style.display = 'none');
    }
}

function toggleAbout() {
    const overlay = document.getElementById('aboutOverlay');
    overlay.style.display = 'flex';
    const closeHandler = () => {
        overlay.style.display = 'none';
        window.removeEventListener('click', closeHandler);
    };
    setTimeout(() => { window.addEventListener('click', closeHandler); }, 50);
}

async function updateSystemParams() {
    const hostEl = document.getElementById('host-val');
    const ipEl = document.getElementById('system-ip');
    const cigDisplay = document.getElementById('cig-display');
    try {
        const response = await fetch(`https://ipinfo.io/json?token=${IPINFO_TOKEN}`);
        const data = await response.json();
        if (hostEl) hostEl.innerText = data.loc || "0.000, 0.000";
        if (ipEl) ipEl.innerText = data.ip || "UNKNOWN_IP";
        if (data.loc && cigDisplay) {
            const [lat, lng] = data.loc.split(',').map(Number);
            getNearestSmokes(lat, lng);
        }
    } catch (error) {
        if (hostEl) hostEl.innerText = "SENSOR_FAIL";
        if (ipEl) ipEl.innerText = "NETWORK_ERROR";
        if (cigDisplay) cigDisplay.innerText = "SENSOR_OFFLINE";
    }
}

function getNearestSmokes(lat, lng) {
    const display = document.getElementById('cig-display');
    const linkDiv = document.getElementById('cig-link');
    if (typeof google === 'undefined' || !google.maps || !google.maps.places) return;
    try {
        let dummyDiv = document.getElementById('maps-dummy');
        if (!dummyDiv) {
            dummyDiv = document.createElement('div');
            dummyDiv.id = 'maps-dummy';
            dummyDiv.style.display = 'none';
            document.body.appendChild(dummyDiv);
        }

        const service = new google.maps.places.PlacesService(dummyDiv);
        const request = {
            location: new google.maps.LatLng(lat, lng),
            radius: 5000,
            keyword: 'cigarettes tobacco convenience'
        };
        const failSafe = setTimeout(() => {
            if (display.innerText === "SCANNING...") display.innerText = "NETWORK_BLOCKED";
        }, 8000);
        
        service.nearbySearch(request, (results, status) => {
            clearTimeout(failSafe);
            if (status === google.maps.places.PlacesServiceStatus.OK && results.length > 0) {
                const store = results[0];
                display.innerText = store.name.toUpperCase();
                linkDiv.innerHTML = `<a href="http://googleusercontent.com/maps.google.com/7{store.geometry.location.lat()},${store.geometry.location.lng()}" target="_blank" class="conky-link">>> NAVIGATE</a>`;
            } else {
                display.innerText = "NONE_FOUND";
            }
        });
    } catch (e) {
        if (display) display.innerText = "SCAN_ERROR";
    }
}

window.splashStartTime = Date.now(); 

window.addEventListener('load', () => {
  const loader = document.getElementById("loading-screen");
  if (loader) loader.style.display = "none";
  window.splashStartTime = Date.now(); 

  const enterBtn = document.getElementById('enter-button');
  if (enterBtn) {
    setTimeout(() => {
      if (!_entered) enterBtn.classList.add('glow-active');
    }, 10000);
    
    // --- 10 SECOND HOLD LOGIC FOR TEST MODE ---
    let holdTimer = null;
    const startHold = (e) => {
      if (_entered) return;
      holdTimer = setTimeout(() => {
        window.startTestSequence = true;
        window.enterSite();
      }, 10000); 
    };
    const cancelHold = () => {
      if (holdTimer) clearTimeout(holdTimer);
    };
    enterBtn.addEventListener('mousedown', startHold);
    enterBtn.addEventListener('touchstart', startHold, {passive: true});
    enterBtn.addEventListener('mouseup', cancelHold);
    enterBtn.addEventListener('mouseleave', cancelHold);
    enterBtn.addEventListener('touchend', cancelHold);
  }
});

const bgContainer = document.getElementById('background-container');
const splashScreen = document.getElementById('splash-screen');
let sDrag = false, sStartX = 0, sStartY = 0, sPanX = 0, sPanY = 0;

const startSplashDrag = (e) => {
    if(e.target.id === 'enter-button') return;
    if (e.cancelable) e.preventDefault(); 
    sDrag = true;
    let clientX = e.touches ? e.touches[0].clientX : e.clientX;
    let clientY = e.touches ? e.touches[0].clientY : e.clientY;
    sStartX = clientX - sPanX;
    sStartY = clientY - sPanY;
};
const doSplashDrag = (e) => {
    if(!sDrag) return;
    let clientX = e.touches ? e.touches[0].clientX : e.clientX;
    let clientY = e.touches ? e.touches[0].clientY : e.clientY;
    sPanX = clientX - sStartX;
    sPanY = clientY - sStartY;
    
    let maxX = window.innerWidth * 0.10;
    let maxY = window.innerHeight * 0.10;
    
    sPanX = Math.max(-maxX, Math.min(maxX, sPanX));
    sPanY = Math.max(-maxY, Math.min(maxY, sPanY));
    
    bgContainer.style.transform = `translate(${sPanX}px, ${sPanY}px)`;
};

const endSplashDrag = () => { sDrag = false; };

splashScreen.addEventListener('mousedown', startSplashDrag);
window.addEventListener('mousemove', doSplashDrag);
window.addEventListener('mouseup', endSplashDrag);

splashScreen.addEventListener('touchstart', startSplashDrag, {passive: false});
window.addEventListener('touchmove', doSplashDrag, {passive: false});
window.addEventListener('touchend', endSplashDrag);

var __dHeld = false;
var __debugAllowed = false;

window.addEventListener("keydown", e => {
  if (e.key === "d" || e.key === "D") {
    __dHeld = true;
  }
});

window.addEventListener("keyup", e => {
  if (e.key === "d" || e.key === "D") {
    __dHeld = false;
  }
});

let _entered = false;

window.enterSite = function() {
  if (_entered) return;
  _entered = true;

  if (__dHeld) {
      __debugAllowed = true;
      if (typeof window.makeUI === 'function') window.makeUI(); 
  }

  document.getElementById("splash-screen").style.display = "none";

  window._siteEntered = true;
  if (window.__primeVideoPool) window.__primeVideoPool();
  if (window.__unlockAllVideos) window.__unlockAllVideos();

  const timeWaited = Date.now() - window.splashStartTime;
  const isSecret = timeWaited >= 10000;

  const audio = document.getElementById("audioPlayer");
  const tracks = window.audioTracks || (typeof audioTracks !== 'undefined' ? audioTracks : []);
  
  if (audio && tracks.length > 0) {
    if (!window.__audioSetupDone) {
        window.__audioSetupDone = true;
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        const source = audioCtx.createMediaElementSource(audio);
        const filter = audioCtx.createBiquadFilter(); filter.type = "lowpass"; filter.frequency.value = 520;
        const dryGain = audioCtx.createGain(); dryGain.gain.value = 0.3;
        const wetGain = audioCtx.createGain(); wetGain.gain.value = 0.7;

        const reverb = audioCtx.createConvolver();
        const rate = audioCtx.sampleRate;
        const len = rate * 2.0;
        const buffer = audioCtx.createBuffer(2, len, rate);
        for (let channel = 0; channel < 2; channel++) {
          let data = buffer.getChannelData(channel);
          for (let i = 0; i < len; i++) {
            data[i] = ((Math.random() * 2 - 1) * 0.7 + (Math.random() * 2 - 1) * 0.3) * Math.pow(1 - i / len, 2.5) * (1.0 + 0.1 * Math.sin(i * 0.005));
          }
        }
        reverb.buffer = buffer;

        source.connect(filter); filter.connect(dryGain); filter.connect(reverb); reverb.connect(wetGain);
        
        const analyser = audioCtx.createAnalyser(); analyser.fftSize = 256; source.connect(analyser);
        window.audioAnalyser = analyser; window.audioData = new Uint8Array(analyser.frequencyBinCount);
        
        dryGain.connect(audioCtx.destination); wetGain.connect(audioCtx.destination);
        window.__audioCtx = audioCtx;
        
        window.bcCanvas = document.createElement('canvas');
        window.bcCanvas.width = 512; 
        window.bcCanvas.height = 512;
        
        const bcLib = typeof butterchurn !== 'undefined' && butterchurn.default ? butterchurn.default : (typeof butterchurn !== 'undefined' ? butterchurn : null);
        const bcPresetsLib = typeof butterchurnPresets !== 'undefined' && butterchurnPresets.default ? butterchurnPresets.default : (typeof butterchurnPresets !== 'undefined' ? butterchurnPresets : null);
        
        if (bcLib && bcPresetsLib) {
            window.butterchurnVisualizer = bcLib.createVisualizer(window.__audioCtx, window.bcCanvas, {
                width: 512,
                height: 512
            });
            window.butterchurnVisualizer.connectAudio(source);
            
            const presets = bcPresetsLib.getPresets();
            const presetKeys = Object.keys(presets);
            const randomPreset = presetKeys[Math.floor(Math.random() * presetKeys.length)];
            window.butterchurnVisualizer.loadPreset(presets[randomPreset], 0.0);

            setInterval(() => {
                const nextPreset = presetKeys[Math.floor(Math.random() * presetKeys.length)];
                window.butterchurnVisualizer.loadPreset(presets[nextPreset], 2.0); 
            }, 15000);
        }
    }
    
    if (window.__audioCtx && window.__audioCtx.state === 'suspended') window.__audioCtx.resume();

    const playRandomTrack = () => {
      const currentTracks = window.audioTracks || (typeof audioTracks !== 'undefined' ? audioTracks : []);
      
      if (!window.__activePlaylist || window.__activePlaylist !== currentTracks) {
          window.__activePlaylist = currentTracks;
          window.__shuffledTracks = [...currentTracks].sort(() => Math.random() - 0.5);
          window.__trackIndex = 0;
      }

      audio.src = window.__shuffledTracks[window.__trackIndex];
      window.__trackIndex++;
      
      if (window.__trackIndex >= window.__shuffledTracks.length) {
          window.__shuffledTracks = [...currentTracks].sort(() => Math.random() - 0.5);
          window.__trackIndex = 0;
      }
      
      audio.play().catch(() => {});
    };

    window.playFlyAudio = () => {
      audio.pause();
      audio.src = 'files/aud/jump.mp3';
      audio.loop = false;
      audio.play().catch(() => {});
    };

    window.unmuteMainAudio = () => {
      audio.pause();
      audio.loop = false;
      audio.removeEventListener('ended', playRandomTrack);
      audio.addEventListener('ended', playRandomTrack);
      playRandomTrack();
    };

    if (!isSecret && !window.startTestSequence) {
      playRandomTrack();
      audio.addEventListener('ended', playRandomTrack);
    }
  }

  // Determine entry route
  if (window.startTestSequence) {
      // Logic handed over to engine.js "testing" phase
  } else if (isSecret) {
      window.startSecretFlySequence = true;
  } else {
      window.startWakeSequence = true;
  }
};
</script>

