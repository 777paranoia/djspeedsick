((window.GLSL = window.GLSL || {}),
  (window.GLSL.modules = window.GLSL.modules || {}),
  (GLSL.modules.deadcity = `
float dcBoxSDF(vec3 p, vec3 b) {
  vec3 q = abs(p) - b;
  return length(max(q, 0.0)) + min(max(q.x, max(q.y, q.z)), 0.0);
}

vec2 dcCenterTowers(vec3 p) {
  vec2 r = vec2(1e5, 0.0);

  vec3 h1Front = vec3(0.48, 15.8, 0.78);
  vec3 h2Front = vec3(0.48, 15.4, 0.78);

  vec3 h1Back = vec3(1.18, 15.8, 1.02);
  vec3 h2Back = vec3(1.18, 15.4, 1.02);

  float d1FrontA = dcBoxSDF(p - vec3(-1.12, -2.1, -10.8), h1Front);
  float d1FrontB = dcBoxSDF(p - vec3(-1.12, -2.1, 10.8), h1Front);
  float d1BackA = dcBoxSDF(p - vec3(-1.12, -2.1, -17.6), h1Back);
  float d1BackB = dcBoxSDF(p - vec3(-1.12, -2.1, 17.6), h1Back);

  float d1 = min(min(d1FrontA, d1FrontB), min(d1BackA, d1BackB));

  if (d1 < r.x) {
    r = vec2(d1, -5.0);
  }

  float d2FrontA = dcBoxSDF(p - vec3(1.12, -1.9, -12.2), h2Front);
  float d2FrontB = dcBoxSDF(p - vec3(1.12, -1.9, 12.2), h2Front);
  float d2BackA = dcBoxSDF(p - vec3(1.12, -1.9, -19.0), h2Back);
  float d2BackB = dcBoxSDF(p - vec3(1.12, -1.9, 19.0), h2Back);

  float d2 = min(min(d2FrontA, d2FrontB), min(d2BackA, d2BackB));

  if (d2 < r.x) {
    r = vec2(d2, -6.0);
  }

  return r;
}

vec2 dcDeadcityMap(vec3 p, bool buildings) {
  vec2 base = mapScene(p, buildings);
  vec2 center = dcCenterTowers(p);

  if (center.x < base.x) {
    base = center;
  }

  return base;
}

void main() {
  vec3 ro, rd, clean_rd;
  setupCamera(ro, rd, clean_rd, 0.0);

  float t = 0.0;
  vec2 hit = vec2(0.0);

  for (int i = 0; i < 90; i++) {
    hit = dcDeadcityMap(ro + rd * t, true);

    if (hit.x < 0.001 || t > 70.0) {
      break;
    }

    t += hit.x;
  }

  vec3 cGreen = vec3(0.055, 0.070, 0.085);
  vec3 cRed = vec3(0.40, 0.09, 0.025);
  vec3 cAmber = vec3(1.0, 0.32, 0.040);

  float traffic = noise1(rd.x * 3.0 + rd.y * 5.0 + u_time * 0.035);

  vec3 skyTone =
    mix(
      vec3(0.003, 0.005, 0.009),
      vec3(0.026, 0.034, 0.044),
      exp(-max(rd.y, 0.0) * 4.0)
    ) +
    vec3(0.26, 0.055, 0.016) *
      pow(traffic, 2.8) *
      smoothstep(0.10, -0.78, rd.y) *
      0.12;

  vec3 col = vec3(0.0);

  if (t < 70.0) {
    vec3 p = ro + rd * t;

    if (hit.y >= 10.0) {
      col = mix(
        colorPickover(p),
        skyTone * 0.15,
        1.0 -
          exp(
            -0.015 *
              max(length(p) - 0.8, 0.0) *
              max(length(p) - 0.8, 0.0)
          )
      );
    } else {
      vec3 n = normalize(
        vec3(
          dcDeadcityMap(p + vec3(0.01, 0, 0), true).x -
            dcDeadcityMap(p - vec3(0.01, 0, 0), true).x,
          dcDeadcityMap(p + vec3(0, 0.01, 0), true).x -
            dcDeadcityMap(p - vec3(0, 0.01, 0), true).x,
          dcDeadcityMap(p + vec3(0, 0, 0.01), true).x -
            dcDeadcityMap(p - vec3(0, 0, 0.01), true).x
        )
      );

      vec2 texUV = abs(n.x) > abs(n.y) ? p.zy : p.xy;

      float c5Hit = step(-5.5, hit.y) * step(hit.y, -4.5);
      float c6Hit = step(-6.5, hit.y) * step(hit.y, -5.5);
      float centerHit = clamp(c5Hit + c6Hit, 0.0, 1.0);

      float frontFace = step(abs(n.x), abs(n.z));
      float centerBackRow = smoothstep(15.0, 17.0, abs(p.z));

      vec2 c5FrontUV = vec2(
        (p.x + mix(1.60, 2.30, centerBackRow)) /
          mix(0.96, 2.36, centerBackRow),
        1.0 - (p.y + 17.9) / 31.8
      );

      vec2 c6FrontUV = vec2(
        (p.x - mix(0.64, -0.06, centerBackRow)) /
          mix(0.96, 2.36, centerBackRow),
        1.0 - (p.y + 17.3) / 31.0
      );

      vec2 cSideUV = vec2(
        fract(p.z * 0.09),
        clamp(1.0 - (p.y + 17.6) / 31.4, 0.0, 1.0)
      );

      vec2 c5UV = mix(cSideUV, c5FrontUV, frontFace);
      vec2 c6UV = mix(cSideUV, c6FrontUV, frontFace);
      vec2 centerUV = mix(c5UV, c6UV, c6Hit);

      vec3 bTex =
        c5Hit > 0.5
          ? texture2D(u_texB5, clamp(c5UV, 0.0, 1.0)).rgb
          : c6Hit > 0.5
            ? texture2D(u_texB6, clamp(c6UV, 0.0, 1.0)).rgb
            : sampleBuilding(hit.y, texUV);

      col =
        mix(
          bTex * mix(0.25, 0.78, centerHit),
          skyTone,
          1.0 - exp(-mix(0.015, 0.0028, centerHit) * t * t)
        ) +
        mix(cGreen, cRed, sin(p.x * 0.4) * 0.5 + 0.5) *
          (
            noise1(u_time * 0.3 + p.x * 0.1) * 0.4 +
            0.6 +
            smoothstep(0.8, 1.0, sin(p.z * 0.8 + u_time * 2.0)) * 0.2
          ) *
          smoothstep(2.0, -20.0, p.y) *
          0.20 *
          exp(-0.005 * t * t) *
          (1.0 - centerHit * 0.82);

      vec2 burnBaseUV = texUV * vec2(0.105, 0.070);
      vec2 blazeGrid = floor(burnBaseUV * vec2(2.15, 3.10));
      vec2 blazeCell = fract(burnBaseUV * vec2(2.15, 3.10));

      float blazeSeed = hash2(blazeGrid + hit.y * 19.0);

      float oneFrontBuildingFireOnly =
        (1.0 - centerHit) *
        step(0.0, p.x) *
        (1.0 - smoothstep(42.0, 68.0, t));

      float backRowZBand =
        smoothstep(14.0, 16.2, abs(p.z)) *
        (1.0 - smoothstep(22.0, 26.0, abs(p.z)));

      float backRowDepthGate = smoothstep(18.0, 30.0, t);

      float oneBackRowBuildingFireOnly =
        (1.0 - centerHit) *
        step(0.0, p.x) *
        backRowZBand *
        backRowDepthGate;

      float frontBackFireMask = clamp(
        oneFrontBuildingFireOnly + oneBackRowBuildingFireOnly,
        0.0,
        1.0
      );

      float majorFire = step(0.74, blazeSeed) * frontBackFireMask;

      float baseY = 0.08 + 0.22 * hash1(blazeSeed * 17.0 + hit.y);
      float fireClock = u_time * (0.62 + blazeSeed * 0.42);

      float plumeLeanA =
        noise1(blazeCell.y * 2.20 - fireClock * 0.35 + blazeSeed * 11.0) -
        0.5;

      float plumeLeanB =
        noise1(blazeCell.y * 6.50 - fireClock * 0.55 + blazeSeed * 23.0) -
        0.5;

      float plumeLean = plumeLeanA * 0.24 + plumeLeanB * 0.08;

      float x0 = 0.24 + 0.52 * hash1(blazeSeed * 31.0 + hit.y);
      float bodyWidth = 0.22 + 0.10 * hash1(blazeSeed * 43.0);
      float bodyHeight = 0.46 + 0.18 * hash1(blazeSeed * 71.0);

      float fireBody = smoothstep(
        bodyWidth,
        0.035,
        abs(blazeCell.x - x0 + plumeLean)
      );

      float fireRise =
        smoothstep(baseY, baseY + 0.08, blazeCell.y) *
        (1.0 -
          smoothstep(
            baseY + bodyHeight,
            baseY + bodyHeight + 0.20,
            blazeCell.y
          ));

      float rollA = noise1(
        blazeCell.x * 4.0 +
          blazeCell.y * 7.0 -
          fireClock * 1.10 +
          blazeSeed * 13.0
      );

      float rollB = noise1(
        blazeCell.x * 9.0 -
          blazeCell.y * 9.0 -
          fireClock * 1.55 +
          blazeSeed * 29.0
      );

      float rollC = noise1(
        blazeCell.x * 17.0 +
          blazeCell.y * 13.0 -
          fireClock * 2.10 +
          blazeSeed * 47.0
      );

      float turbulentEdge =
        smoothstep(0.16, 0.84, rollA) * mix(0.68, 1.18, rollB);

      float flame = majorFire * fireBody * fireRise * turbulentEdge;

      float lowerCore =
        smoothstep(
          bodyWidth * 0.45,
          0.030,
          abs(blazeCell.x - x0 + plumeLean * 0.35)
        ) *
        smoothstep(baseY + bodyHeight * 0.72, baseY + 0.12, blazeCell.y) *
        smoothstep(baseY - 0.02, baseY + 0.15, blazeCell.y);

      float interiorBlast =
        majorFire *
        lowerCore *
        smoothstep(0.22, 0.88, rollC);

      flame = clamp(max(flame, interiorBlast), 0.0, 1.0);

      vec3 flameCol =
        vec3(1.0, 0.13, 0.015) * flame * 1.75 +
        vec3(1.0, 0.50, 0.08) * interiorBlast * 1.95 +
        vec3(0.90, 0.04, 0.006) * flame * flame * 0.78;

      float smokeStart = baseY + 0.14;
      float smokeRise = smoothstep(smokeStart, 0.995, blazeCell.y);

      float smokeWindA =
        noise1(blazeCell.y * 1.45 - u_time * 0.040 + blazeSeed * 5.0) -
        0.5;

      float smokeWindB =
        noise1(blazeCell.y * 4.20 - u_time * 0.072 + blazeSeed * 13.0) -
        0.5;

      float smokeWindC =
        noise1(blazeCell.y * 8.00 - u_time * 0.105 + blazeSeed * 37.0) -
        0.5;

      float smokeDrift =
        smokeWindA * 0.62 +
        smokeWindB * 0.25 +
        smokeWindC * 0.10;

      float smokeX = x0 + smokeDrift;
      float smokeWidth = mix(0.46, 1.62, smokeRise);

      float blackColumn =
        smoothstep(smokeWidth, 0.030, abs(blazeCell.x - smokeX)) *
        smokeRise;

      float smokeCap =
        smoothstep(baseY + 0.22, 0.98, blazeCell.y) *
        smoothstep(1.78, 0.28, abs(blazeCell.x - smokeX));

      float billowA = noise1(
        blazeCell.x * 3.5 +
          blazeCell.y * 7.0 -
          u_time * 0.120 +
          blazeSeed * 17.0
      );

      float billowB = noise1(
        blazeCell.x * 8.0 -
          blazeCell.y * 6.0 -
          u_time * 0.070 +
          blazeSeed * 31.0
      );

      float billowC = noise1(
        blazeCell.x * 16.0 +
          blazeCell.y * 13.0 -
          u_time * 0.045 +
          blazeSeed * 61.0
      );

      float denseSmoke =
        majorFire *
        max(blackColumn, smokeCap * 0.96) *
        smoothstep(0.06, 0.78, billowA) *
        mix(0.86, 1.36, billowB);

      float shoulderSmoke =
        majorFire *
        smoothstep(smokeWidth * 2.05, 0.08, abs(blazeCell.x - smokeX)) *
        smokeRise *
        smoothstep(0.04, 0.70, billowC) *
        1.06;

      float smoke = clamp(denseSmoke * 1.82 + shoulderSmoke * 1.30, 0.0, 1.0);

      vec3 smokeCol = mix(
        vec3(0.070, 0.075, 0.082),
        vec3(0.0018, 0.0022, 0.0035),
        smoothstep(0.06, 0.80, denseSmoke)
      );

      smokeCol = mix(
        smokeCol,
        vec3(0.020, 0.022, 0.026),
        shoulderSmoke * 0.20
      );

      float burnFog = exp(-0.0032 * t * t);

      col = mix(col, smokeCol, smoke * burnFog * 0.94);
      col *= 1.0 - denseSmoke * burnFog * 0.32;
      col += flameCol * burnFog * 1.20;
      col += vec3(1.0, 0.09, 0.018) * flame * burnFog * 0.12;
    }
  } else {
    col =
      texture2D(
        u_texEnv1,
        fract(rd.xy * 0.5 + 0.5 + vec2(u_time * 0.002, 0.0))
      ).rgb *
        0.3 +
      skyTone * 0.5;
  }

  col += snow(
    vec2(atan(rd.z, rd.x) * 2.0, rd.y * 2.0),
    15.0,
    0.3,
    0.3
  );

  float dWin = (-1.5 - ro.z) / clean_rd.z;

  if (dWin > 0.0) {
    vec3 pW = ro + clean_rd * dWin;
    vec2 wuv = vec2(pW.x * 0.25 + 0.5, 0.5 - pW.y * 0.25);
    vec2 edgeUV = clamp(wuv, 0.0, 1.0);

    vec4 txW = texture2D(u_texWindow, edgeUV);

    if (1.0 - clamp(txW.a, 0.0, 1.0) > 0.1) {
      col = mix(
        col,
        vec3(0.6, 0.7, 0.8),
        hash2(edgeUV * 80.0) * 0.012
      );
    }

    col = mix(col, txW.rgb * 0.45, txW.a);
  }

  col = digitalGlitch(col, gl_FragCoord.xy / u_resolution.xy);

  gl_FragColor = vec4(
    col * (1.0 - u_blink) * 0.78 * smoothstep(0.0, 0.8, u_wake),
    1.0
  );
}
`));